{
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/mcp/", "destination": "/api/mcp" },
    { "source": "/mcp/:path*", "destination": "/api/mcp" },
    { "source": "/finance/admin", "destination": "/api/finance-gate?level=admin" },
    { "source": "/finance/admin/", "destination": "/api/finance-gate?level=admin" },
    { "source": "/finance/investor", "destination": "/api/finance-gate?level=investor" },
    { "source": "/finance/investor/", "destination": "/api/finance-gate?level=investor" }
  ],
  "functions": {
    "api/finance-data.js": {
      "includeFiles": "finance/**"
    }
  }
}
